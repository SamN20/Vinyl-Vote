# Flask Configuration
SECRET_KEY=your-secret-key-here

# Database
# SQLite is used by default (configured in config.py)
# SQLALCHEMY_DATABASE_URI=sqlite:///album_vote.db

# Spotify API
SPOTIPY_CLIENT_ID=your-spotify-client-id
SPOTIPY_CLIENT_SECRET=your-spotify-client-secret

# VAPID Keys for Web Push
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Voting Configuration
VOTE_ACTIVE=True
NEXT_ALBUM_OPTION_COUNT=3

# Email Configuration (Legacy - will be phased out for Nolofication)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER_EMAIL=noreply@vinylvote.com
MAIL_DEFAULT_SENDER_NAME=Vinyl Vote

# API CORS Origins
VINYL_VOTE_API_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# KeyN OAuth Settings
KEYN_AUTH_SERVER_URL=https://auth-keyn.bynolo.ca
KEYN_CLIENT_ID=your-keyn-client-id
KEYN_CLIENT_SECRET=your-keyn-client-secret
KEYN_CLIENT_REDIRECT=http://localhost:5000/oauth/callback
KEYN_DEFAULT_SCOPES=id,username,email,display_name,is_verified
FORCE_KEYN_REGISTRATION=false
FORCE_KEYN_LOGIN=false

# Nolofication Settings
# Centralized notification management system
NOLOFICATION_URL=https://nolofication.bynolo.ca
NOLOFICATION_SITE_ID=vinylvote
NOLOFICATION_API_KEY=your-nolofication-api-key-here

# Session/Cookie Settings
REMEMBER_COOKIE_SECURE=False  # Set to True in production with HTTPS

# Optional deploy-time cache busting
# ASSET_VERSION=202604040001
